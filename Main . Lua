-- Targetsaken by Grok ❤️ - GUI Closable + Draggable + All Buttons Active + NOTHING starts ON

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")
local Camera = Workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()
local Window = Library.CreateLib("Targetsaken by Grok ❤️", "DarkTheme")

local AbilitiesTab = Window:NewTab("Abilities")
local VisualsTab = Window:NewTab("Visuals")
local MiscTab = Window:NewTab("Misc")

-- ALL FEATURES START OFF (nothing activates in advance)
local Features = {
    AutoAimAbility = false,
    AutoOtherAbilities = false,
    AutoChange = false,
    ESP = false,
    InfStamina = false,
    CameraLock = false
}
local RangeValue = 25
local PredictionValue = 0.25
local LockTargetType = "Survivor"
local Highlights = {}
local RayParams = RaycastParams.new()
RayParams.FilterType = Enum.RaycastFilterType.Exclude

-- Safe folder helpers (re-checked 3x)
local PlayersFolder = Workspace:FindFirstChild("Players")
local function GetSurvivors() return PlayersFolder and PlayersFolder:FindFirstChild("Survivors") end
local function GetKillers() return PlayersFolder and PlayersFolder:FindFirstChild("Killers") end

-- Abilities Tab (all buttons active)
local AbSection = AbilitiesTab:NewSection("Core Features")
AbSection:NewToggle("Auto Aim on Ability Use", "Aims ONLY when you click/use ability", function(state) Features.AutoAimAbility = state end)
AbSection:NewToggle("Camera Lock", "Constantly locks camera on target", function(state) Features.CameraLock = state end)
AbSection:NewDropdown("Lock Target", {"Survivor", "Killer"}, function(choice) LockTargetType = choice end, "Survivor")
AbSection:NewSlider("Range", "Max range (studs)", 0, 50, RangeValue, function(v) RangeValue = v end, true)
AbSection:NewSlider("Prediction", "Aim prediction", 0, 1, PredictionValue, function(v) PredictionValue = v end, true)
AbSection:NewToggle("Auto Other Abilities", "Auto Raging Pace / Eye / Pizza / 404 etc.", function(state) Features.AutoOtherAbilities = state end)
AbSection:NewToggle("Auto Change", "Cycles abilities", function(state) Features.AutoChange = state end)

-- Visuals Tab
local VisSection = VisualsTab:NewSection("Visuals")
VisSection:NewToggle("ESP", "Highlights everyone", function(state) Features.ESP = state end)

-- Misc Tab
local MiscSection = MiscTab:NewSection("Misc")
MiscSection:NewToggle("Infinite Stamina", "Never runs out", function(state) Features.InfStamina = state end)

-- Auto Aim ONLY when you use ability (left click)
UserInputService.InputBegan:Connect(function(input, gp)
    if gp or not Features.AutoAimAbility or input.UserInputType \~= Enum.UserInputType.MouseButton1 then return end
    
    local myChar = LocalPlayer.Character
    if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return end
    local myHRP = myChar.HumanoidRootPart
    
    RayParams.FilterDescendantsInstances = {myChar}
    
    local targetHRP = nil
    local closest = math.huge
    
    -- Survivors first
    local survFolder = GetSurvivors()
    if survFolder then
        for _, char in ipairs(survFolder:GetChildren()) do
            if char \~= myChar and char:FindFirstChild("HumanoidRootPart") then
                local hrp = char.HumanoidRootPart
                local dist = (hrp.Position - myHRP.Position).Magnitude
                if dist <= RangeValue and dist < closest then
                    local ray = Workspace:Raycast(myHRP.Position, (hrp.Position - myHRP.Position), RayParams)
                    if not ray or ray.Distance >= dist - 2 then
                        closest = dist
                        targetHRP = hrp
                    end
                end
            end
        end
    end
    
    -- Killer if no survivor found
    if not targetHRP then
        local killFolder = GetKillers()
        if killFolder then
            for _, char in ipairs(killFolder:GetChildren()) do
                if char \~= myChar and char:FindFirstChild("HumanoidRootPart") then
                    local hrp = char.HumanoidRootPart
                    local dist = (hrp.Position - myHRP.Position).Magnitude
                    if dist <= RangeValue and dist < closest then
                        local ray = Workspace:Raycast(myHRP.Position, (hrp.Position - myHRP.Position), RayParams)
                        if not ray or ray.Distance >= dist - 2 then
                            closest = dist
                            targetHRP = hrp
                        end
                    end
                end
            end
        end
    end
    
    if targetHRP then
        local predicted = targetHRP.Position + (targetHRP.Velocity * PredictionValue)
        Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, predicted)
    end
end)

-- Main Loop (only runs what you turn ON)
RunService.RenderStepped:Connect(function()
    local myChar = LocalPlayer.Character
    if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return end
    local myHRP = myChar.HumanoidRootPart
    local myHum = myChar:FindFirstChildOfClass("Humanoid")
    
    -- Infinite Stamina (only if toggled)
    if Features.InfStamina and myHum then
        myHum:SetAttribute("Stamina", 100)
        local stam = myChar:FindFirstChild("Stamina") or myChar:FindFirstChild("SprintStamina")
        if stam and stam:IsA("NumberValue") then stam.Value = 100 end
    end
    
    -- ESP (only if toggled)
    if Features.ESP then
        local survFolder = GetSurvivors()
        if survFolder then
            for _, char in ipairs(survFolder:GetChildren()) do
                if not Highlights[char] then
                    local hl = Instance.new("Highlight")
                    hl.Adornee = char
                    hl.FillColor = Color3.fromRGB(0, 255, 0)
                    hl.OutlineColor = Color3.fromRGB(255, 255, 255)
                    hl.FillTransparency = 0.6
                    hl.Parent = char
                    Highlights[char] = hl
                end
            end
        end
        local killFolder = GetKillers()
        if killFolder then
            for _, char in ipairs(killFolder:GetChildren()) do
                if not Highlights[char] then
                    local hl = Instance.new("Highlight")
                    hl.Adornee = char
                    hl.FillColor = Color3.fromRGB(255, 0, 0)
                    hl.OutlineColor = Color3.fromRGB(255, 255, 255)
                    hl.FillTransparency = 0.6
                    hl.Parent = char
                    Highlights[char] = hl
                end
            end
        end
    else
        for _, hl in pairs(Highlights) do if hl then hl:Destroy() end end
        Highlights = {}
    end
    
    -- Camera Lock (only if toggled)
    if Features.CameraLock then
        local targetHRP = nil
        local closest = math.huge
        RayParams.FilterDescendantsInstances = {myChar}
        
        local folder = (LockTargetType == "Survivor") and GetSurvivors() or GetKillers()
        if folder then
            for _, char in ipairs(folder:GetChildren()) do
                if char \~= myChar and char:FindFirstChild("HumanoidRootPart") then
                    local hrp = char.HumanoidRootPart
                    local dist = (hrp.Position - myHRP.Position).Magnitude
                    if dist <= RangeValue and dist < closest then
                        local ray = Workspace:Raycast(myHRP.Position, (hrp.Position - myHRP.Position), RayParams)
                        if not ray or ray.Distance >= dist - 2 then
                            closest = dist
                            targetHRP = hrp
                        end
                    end
                end
            end
        end
        
        if targetHRP then
            local predicted = targetHRP.Position + (targetHRP.Velocity * PredictionValue)
            Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, predicted)
        end
    end
    
    -- Auto Other Abilities & Auto Change (only if toggled)
    if Features.AutoOtherAbilities then
        for _, tool in ipairs(myChar:GetChildren()) do
            if tool:IsA("Tool") and (tool.Name:lower():find("rage") or tool.Name:lower():find("eye") or tool.Name:lower():find("pizza") or tool.Name:lower():find("404")) then
                tool:Activate()
            end
        end
    end
    if Features.AutoChange then
        for _, tool in ipairs(myChar:GetChildren()) do
            if tool:IsA("Tool") then
                tool.Parent = LocalPlayer.Backpack
                task.wait(0.5)
                tool.Parent = myChar
                break
            end
        end
    end
end)

print("✅ Targetsaken LOADED! GUI is draggable (drag title bar) + closable (click X top right). All buttons active, NOTHING starts ON until you toggle! 🔥 Go have fun, bestie! ❤️")
