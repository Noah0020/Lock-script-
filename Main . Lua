-- Settings
local LockEnabled = false
local TargetPriority = "Center"
local LockedTarget = nil
local PredictionFactor = 0.25
local BodyOffset = Vector3.new(0, 2, 0)
local CameraDistance = 12
local CameraHeight = 5

-- Validate characters
local function isValidCharacter(char)
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    return hum and hrp and hum.Health > 0
end

local function isEnemy(player)
    if player == LocalPlayer then return false end
    return player.Character and true or false
end

local function getTarget()
    local best, bestValue = nil, math.huge
    local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    for _, player in ipairs(Players:GetPlayers()) do
        if isEnemy(player) then
            local char = player.Character
            if isValidCharacter(char) then
                local hrp = char.HumanoidRootPart
                local screenPos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
                if onScreen then
                    if TargetPriority == "Center" then
                        local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                        if dist < bestValue then
                            bestValue = dist
                            best = hrp
                        end
                    else
                        local hp = char:FindFirstChildOfClass("Humanoid").Health
                        if hp < bestValue then
                            bestValue = hp
                            best = hrp
                        end
                    end
                end
            end
        end
    end
    return best
end

-- Main lock loop
RunService.RenderStepped:Connect(function()
    if not LockEnabled then return end
    local char = LocalPlayer.Character
    local charHRP = char and char:FindFirstChild("HumanoidRootPart")
    if not charHRP then return end

    if not LockedTarget or not LockedTarget.Parent then
        LockedTarget = getTarget()
    end
    if not LockedTarget then return end

    local targetHRP = LockedTarget
    local vel = targetHRP.AssemblyLinearVelocity or targetHRP.Velocity
    local predicted = targetHRP.Position + vel * PredictionFactor + BodyOffset

    -- Character hard lock
    local flatTarget = Vector3.new(predicted.X, charHRP.Position.Y, predicted.Z)
    charHRP.CFrame = CFrame.lookAt(charHRP.Position, flatTarget)

    -- Camera behind player
    local behindPos = charHRP.Position - charHRP.CFrame.LookVector*CameraDistance + Vector3.new(0, CameraHeight, 0)
    Camera.CFrame = CFrame.new(behindPos, predicted)
end)

