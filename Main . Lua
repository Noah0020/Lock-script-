local pred = 1

local camDist = 12
local camHeight = 5
local yOffset = Vector3.new(0,2,0)

-- target check
local function validChar(c)
    if not c then return false end
    local h = c:FindFirstChildOfClass("Humanoid")
    local r = c:FindFirstChild("HumanoidRootPart")
    return h and r and h.Health > 0
end

-- get closest to screen center
local function getTarget()
    local best, dist = nil, math.huge
    local center = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)

    for _,v in ipairs(Players:GetPlayers()) do
        if v ~= plr and v.Character and validChar(v.Character) then
            local hrp = v.Character.HumanoidRootPart
            local pos, onScreen = cam:WorldToViewportPoint(hrp.Position)

            if onScreen then
                local d = (Vector2.new(pos.X,pos.Y) - center).Magnitude
                if d < dist then
                    dist = d
                    best = hrp
                end
            end
        end
    end

    return best
end

-- camera lock (FIXED)
RunService.RenderStepped:Connect(function()
    if not enabled then return end

    local char = plr.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    if not target or not target.Parent or not validChar(target.Parent) then
        target = getTarget()
    end
    if not target then return end

    local vel = target.AssemblyLinearVelocity or Vector3.zero
    local aimPos = target.Position + vel * pred + yOffset

    -- keep camera behind player
    local behind = hrp.Position - hrp.CFrame.LookVector * camDist + Vector3.new(0, camHeight, 0)

    -- HARD LOCK (no freecam bug)
    cam.CFrame = CFrame.lookAt(behind, aimPos)
end)

