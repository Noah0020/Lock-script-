-- TARGETSAKEN v8 | FULLY FIXED (Mobile + PC)

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")

local LocalPlayer = Players.LocalPlayer
local Camera = Workspace.CurrentCamera
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

-- SETTINGS
local LockEnabled = false
local LockMode = "Camera"
local TargetPriority = "Center"
local LockedTarget = nil

-- =========================
-- 🧠 TARGET SYSTEM
-- =========================

local function isValidCharacter(char)
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    return hum and hrp and hum.Health > 0
end

local function isEnemy(player)
    if player == LocalPlayer then return false end
    if not player.Character then return false end

    if player.Team and LocalPlayer.Team then
        return player.Team ~= LocalPlayer.Team
    end

    return true
end

local function isVisible(targetPart)
    local origin = Camera.CFrame.Position
    local direction = (targetPart.Position - origin)

    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {LocalPlayer.Character}
    params.FilterType = Enum.RaycastFilterType.Blacklist

    local result = Workspace:Raycast(origin, direction, params)

    if result then
        return result.Instance:IsDescendantOf(targetPart.Parent)
    end

    return true
end

local function getTarget()
    local best, bestValue = nil, math.huge
    local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)

    for _, player in ipairs(Players:GetPlayers()) do
        if isEnemy(player) then
            local char = player.Character

            if isValidCharacter(char) then
                local hrp = char.HumanoidRootPart
                local pos, visible = Camera:WorldToViewportPoint(hrp.Position)

                if visible then
                    if TargetPriority == "Center" then
                        local dist = (Vector2.new(pos.X,pos.Y) - center).Magnitude
                        if dist < bestValue then
                            bestValue = dist
                            best = hrp
                        end
                    else
                        local hp = char:FindFirstChildOfClass("Humanoid").Health
                        if hp < bestValue then
                            bestValue = hp
                            best = hrp
                        end
                    end
                end
            end
        end
    end

    return best
end

-- =========================
-- 🔒 LOCK SYSTEM (FINAL)
-- =========================

RunService.RenderStepped:Connect(function()
    if not LockEnabled then return end

    if not LockedTarget or not LockedTarget.Parent then
        LockedTarget = getTarget()
    end

    if not LockedTarget then return end

    local camPos = Camera.CFrame.Position
    local targetPos = LockedTarget.Position

    local dist = (camPos - targetPos).Magnitude

    if dist > 350 then
        LockedTarget = nil
        return
    end

    local vel = LockedTarget.AssemblyLinearVelocity or LockedTarget.Velocity
    local prediction = math.clamp(dist / 150, 0.12, 0.25)
    local predicted = targetPos + (vel * prediction)

    if not isVisible(LockedTarget) then
        predicted = targetPos
    end

    if LockMode == "Camera" then
        local lookCF = CFrame.lookAt(camPos, predicted)
        Camera.CFrame = Camera.CFrame:Lerp(lookCF, 0.45)
    else
        local char = LocalPlayer.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")

        if hrp then
            local flatTarget = Vector3.new(predicted.X, hrp.Position.Y, predicted.Z)
            local lookCF = CFrame.lookAt(hrp.Position, flatTarget)

            hrp.CFrame = hrp.CFrame:Lerp(lookCF, 0.45)
        end
    end
end)

-- =========================
-- 🎨 GUI (RECTANGULAR)
-- =========================

local gui = Instance.new("ScreenGui")
gui.Name = "TargetsakenUI"
gui.ResetOnSpawn = false
gui.Parent = PlayerGui

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0,240,0,170)
frame.Position = UDim2.new(0.7,0,0.6,0)
frame.BackgroundColor3 = Color3.fromRGB(30,30,30)
frame.Parent = gui
Instance.new("UICorner",frame)

local function makeBtn(text,y)
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(1,-10,0,32)
    b.Position = UDim2.new(0,5,0,y)
    b.Text = text
    b.BackgroundColor3 = Color3.fromRGB(50,50,50)
    b.TextColor3 = Color3.new(1,1,1)
    b.Parent = frame
    Instance.new("UICorner",b)
    return b
end

local lockBtn = makeBtn("OFF",10)
local modeBtn = makeBtn("MODE: CAM",50)
local prioBtn = makeBtn("CENTER",90)

-- toggle button
local toggle = Instance.new("TextButton")
toggle.Size = UDim2.new(0,40,0,40)
toggle.Position = UDim2.new(0.7,0,0.55,0)
toggle.Text = "≡"
toggle.Parent = gui

local visible = true
toggle.MouseButton1Click:Connect(function()
    visible = not visible
    frame.Visible = visible
end)

-- button logic
lockBtn.MouseButton1Click:Connect(function()
    LockEnabled = not LockEnabled
    lockBtn.Text = LockEnabled and "ON" or "OFF"
    if not LockEnabled then LockedTarget = nil end
end)

modeBtn.MouseButton1Click:Connect(function()
    if LockMode == "Camera" then
        LockMode = "Character"
        modeBtn.Text = "MODE: CHAR"
    else
        LockMode = "Camera"
        modeBtn.Text = "MODE: CAM"
    end
end)

prioBtn.MouseButton1Click:Connect(function()
    if TargetPriority == "Center" then
        TargetPriority = "LowestHP"
        prioBtn.Text = "LOW HP"
    else
        TargetPriority = "Center"
        prioBtn.Text = "CENTER"
    end
    LockedTarget = nil
end)

-- =========================
-- 📱 DRAG FIX (MOBILE + PC)
-- =========================

local dragging = false
local dragStart, startPos

frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 
    or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = frame.Position
    end
end)

frame.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 
    or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement 
    or input.UserInputType == Enum.UserInputType.Touch) then

        local delta = input.Position - dragStart

        frame.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end
end)
