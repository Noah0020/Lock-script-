local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UIS = game:GetService("UserInputService")
local Camera = workspace.CurrentCamera

local lp = Players.LocalPlayer
local pg = lp:WaitForChild("PlayerGui")

local lock = false
local target
local pred = 0.25
local yOffset = Vector3.new(0,2,0)
local camDist = 12
local camHeight = 5

local function validChar(c)
    local h = c:FindFirstChildOfClass("Humanoid")
    local r = c:FindFirstChild("HumanoidRootPart")
    return h and r and h.Health > 0
end

local function getClosest()
    local best, val = nil, math.huge
    local mid = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= lp and p.Character and validChar(p.Character) then
            local hrp = p.Character.HumanoidRootPart
            local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
            if onScreen then
                local d = (Vector2.new(pos.X,pos.Y) - mid).Magnitude
                if d < val then
                    val = d
                    best = hrp
                end
            end
        end
    end
    return best
end

RunService.RenderStepped:Connect(function()
    if not lock then return end
    local char = lp.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    if not target or not target.Parent then
        target = getClosest()
    end
    if not target then return end

    local vel = target.AssemblyLinearVelocity or Vector3.zero
    local aim = target.Position + vel * pred + yOffset

    local camPos = hrp.Position - (aim - hrp.Position).Unit * camDist + Vector3.new(0, camHeight, 0)
    Camera.CFrame = CFrame.new(camPos, aim)
end)

-- GUI
local gui = Instance.new("ScreenGui", pg)
gui.ResetOnSpawn = false

local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0,250,0,100)
frame.Position = UDim2.new(.7,0,.6,0)
frame.BackgroundColor3 = Color3.fromRGB(30,30,30)
Instance.new("UICorner", frame)

local lockBtn = Instance.new("TextButton", frame)
lockBtn.Size = UDim2.new(1,-10,0,30)
lockBtn.Position = UDim2.new(0,5,0,10)
lockBtn.Text = "LOCK: OFF"
lockBtn.BackgroundColor3 = Color3.fromRGB(50,50,50)
lockBtn.TextColor3 = Color3.new(1,1,1)
Instance.new("UICorner", lockBtn)

local predLabel = Instance.new("TextLabel", frame)
predLabel.Size = UDim2.new(1,-10,0,20)
predLabel.Position = UDim2.new(0,5,0,50)
predLabel.Text = "Prediction: "..pred
predLabel.TextColor3 = Color3.new(1,1,1)
predLabel.BackgroundTransparency = 1

local predBox = Instance.new("TextBox", frame)
predBox.Size = UDim2.new(1,-10,0,20)
predBox.Position = UDim2.new(0,5,0,70)
predBox.Text = tostring(pred)
predBox.ClearTextOnFocus = false
predBox.TextColor3 = Color3.new(1,1,1)
predBox.BackgroundColor3 = Color3.fromRGB(50,50,50)
Instance.new("UICorner", predBox)

-- Buttons
lockBtn.MouseButton1Click:Connect(function()
    lock = not lock
    lockBtn.Text = lock and "LOCK: ON" or "LOCK: OFF"
    if not lock then target = nil end
end)

predBox.FocusLost:Connect(function(enter)
    local n = tonumber(predBox.Text)
    if n and n >= 0 and n <= 10 then
        pred = n
        predLabel.Text = "Prediction: "..pred
    else
        predBox.Text = tostring(pred)
    end
end)

-- Draggable frame
local function drag(obj)
    local dragging, dragInput, startPos, startFrame
    obj.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            startPos = input.Position
            startFrame = obj.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    obj.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            dragInput = input
        end
    end)
    UIS.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - startPos
            obj.Position = UDim2.new(
                startFrame.X.Scale, startFrame.X.Offset + delta.X,
                startFrame.Y.Scale, startFrame.Y.Offset + delta.Y
            )
        end
    end)
end

drag(frame)
