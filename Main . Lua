-- GET GROUP
local function getGroup()
    if TargetType == "Killer" then
        return Workspace:FindFirstChild("Killers")
    else
        return Workspace:FindFirstChild("Survivors")
    end
end

-- VALID TARGET
local function isValidTarget(hrp)
    if not hrp or not hrp.Parent then return false end
    local humanoid = hrp.Parent:FindFirstChildOfClass("Humanoid")
    return humanoid and humanoid.Health > 0
end

-- FIND TARGET
local function getNewTarget()
    local group = getGroup()
    if not group then return nil end

    local best, bestValue = nil, math.huge
    local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)

    for _, char in ipairs(group:GetChildren()) do
        if char ~= LocalPlayer.Character and char:FindFirstChild("HumanoidRootPart") then
            local hrp = char.HumanoidRootPart
            local humanoid = char:FindFirstChildOfClass("Humanoid")

            if humanoid and humanoid.Health > 0 then
                local screenPos, onScreen = Camera:WorldToViewportPoint(hrp.Position)

                if onScreen then
                    if TargetPriority == "Center" then
                        local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                        if dist < bestValue then
                            bestValue = dist
                            best = hrp
                        end
                    else
                        if humanoid.Health < bestValue then
                            bestValue = humanoid.Health
                            best = hrp
                        end
                    end
                end
            end
        end
    end

    return best
end

-- HARD LOCK LOOP
RunService.RenderStepped:Connect(function()
    if not LockEnabled then return end

    if not isValidTarget(LockedTarget) then
        LockedTarget = getNewTarget()
    end

    if not LockedTarget then return end

    local predicted = LockedTarget.Position + (LockedTarget.Velocity * PredictionMultiplier)
    local camPos = Camera.CFrame.Position
    local distance = (predicted - camPos).Magnitude

    local strength
    if distance < 20 then
        strength = 0.6
    elseif distance < 50 then
        strength = 0.4
    else
        strength = 0.25
    end

    if distance < 12 then
        Camera.CFrame = CFrame.lookAt(camPos, predicted)
    else
        Camera.CFrame = Camera.CFrame:Lerp(
            CFrame.lookAt(camPos, predicted),
            strength
        )
    end
end)
