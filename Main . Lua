local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UIS = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")

local plr = Players.LocalPlayer
local cam = Workspace.CurrentCamera
local guiParent = plr:WaitForChild("PlayerGui")

local enabled = false
local mode = "Center"
local target = nil

local pred = 0.25
local yOffset = Vector3.new(0,2,0)

local camDist = 12
local camHeight = 5

local function validChar(c)
    if not c then return false end
    local h = c:FindFirstChildOfClass("Humanoid")
    local r = c:FindFirstChild("HumanoidRootPart")
    return h and r and h.Health > 0
end

local function getTarget()
    local best, val = nil, math.huge
    local middle = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)

    for _,v in ipairs(Players:GetPlayers()) do
        if v ~= plr and v.Character and validChar(v.Character) then
            local hrp = v.Character.HumanoidRootPart
            local pos, onScreen = cam:WorldToViewportPoint(hrp.Position)

            if onScreen then
                if mode == "Center" then
                    local dist = (Vector2.new(pos.X,pos.Y) - middle).Magnitude
                    if dist < val then
                        val = dist
                        best = hrp
                    end
                else
                    local hp = v.Character:FindFirstChildOfClass("Humanoid").Health
                    if hp < val then
                        val = hp
                        best = hrp
                    end
                end
            end
        end
    end

    return best
end

RunService.RenderStepped:Connect(function()
    if not enabled then return end

    local char = plr.Character
    if not char then return end

    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    if not target or not target.Parent then
        target = getTarget()
    end
    if not target then return end

    local vel = target.AssemblyLinearVelocity or target.Velocity
    local aimPos = target.Position + vel * pred + yOffset

    hrp.CFrame = CFrame.lookAt(hrp.Position, Vector3.new(aimPos.X, hrp.Position.Y, aimPos.Z))

    local camPos = hrp.Position - hrp.CFrame.LookVector * camDist + Vector3.new(0, camHeight, 0)
    cam.CFrame = CFrame.new(camPos, aimPos)
end)

