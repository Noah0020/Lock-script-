-- Drag frame
do
    local dragging=false
    local dragInput
    local dragStart
    local startPos
    frame.InputBegan:Connect(function(input)
        if input.UserInputType==Enum.UserInputType.MouseButton1 then
            dragging=true
            dragStart=input.Position
            startPos=frame.Position
            input.Changed:Connect(function()
                if input.UserInputState==Enum.UserInputState.End then dragging=false end
            end)
        end
    end)
    frame.InputChanged:Connect(function(input)
        if input.UserInputType==Enum.UserInputType.MouseMovement then dragInput=input end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input==dragInput then
            local delta=input.Position-dragStart
            frame.Position=UDim2.new(
                startPos.X.Scale,startPos.X.Offset+delta.X,
                startPos.Y.Scale,startPos.Y.Offset+delta.Y
            )
        end
    end)
end

-- ===== LOCK SYSTEM =====
local LockEnabled=false
local LockMode="Camera" -- Camera/Character
local TargetType="Survivor" -- Survivor/Killer
local TargetPriority="Center" -- Center/LowestHP
local LockedTarget=nil
local Smoothness=0.18
local PredictionMultiplier=0.25

-- Helpers
local function isValidTarget(hrp)
    if not hrp or not hrp.Parent then return false end
    local humanoid=hrp.Parent:FindFirstChildOfClass("Humanoid")
    return humanoid and humanoid.Health>0
end

local function getNewTarget()
    local bestTarget,bestValue=nil,math.huge
    local center2D=Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    local container=Workspace:FindFirstChild(TargetType.."s")
    local candidates={}
    if container then
        candidates=container:GetChildren()
    else
        for _,obj in ipairs(Workspace:GetDescendants()) do
            if obj:IsA("Model") and obj:FindFirstChild("HumanoidRootPart") then
                table.insert(candidates,obj)
            end
        end
    end
    for _,char in ipairs(candidates) do
        if char~=LocalPlayer.Character and char:FindFirstChild("HumanoidRootPart") then
            local hrp=char.HumanoidRootPart
            local humanoid=char:FindFirstChildOfClass("Humanoid")
            if humanoid and humanoid.Health>0 then
                local screenPos,onScreen=Camera:WorldToViewportPoint(hrp.Position)
                if onScreen then
                    if TargetPriority=="Center" then
                        local dist=(Vector2.new(screenPos.X,screenPos.Y)-center2D).Magnitude
                        if dist<bestValue then
                            bestValue=dist
                            bestTarget=hrp
                        end
                    else -- LowestHP
                        if humanoid.Health<bestValue then
                            bestValue=humanoid.Health
                            bestTarget=hrp
                        end
                    end
                end
            end
        end
    end
    return bestTarget
end

-- Main update
RunService.RenderStepped:Connect(function()
    if not LockEnabled then return end
    if not isValidTarget(LockedTarget) then
        LockedTarget=getNewTarget()
    end
    if not LockedTarget then return end

    local predicted=LockedTarget.Position + (LockedTarget.Velocity*PredictionMultiplier)
    if LockMode=="Camera" then
        Camera.CFrame=Camera.CFrame:Lerp(
            CFrame.lookAt(Camera.CFrame.Position,predicted),
            Smoothness
        )
    else
        local char=LocalPlayer.Character
        local charHRP=char and char:FindFirstChild("HumanoidRootPart")
        if charHRP then
            charHRP.CFrame=charHRP.CFrame:Lerp(
                CFrame.lookAt(charHRP.Position,predicted),
                Smoothness
            )
        end
    end
end)

