-- TARGETSAKEN FULL SCRIPT | Hard Lock + Camera + Character + Prediction

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")

local LocalPlayer = Players.LocalPlayer
local Camera = Workspace.CurrentCamera
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

-- SETTINGS
local LockEnabled = false
local TargetPriority = "Center" -- "Center" or "LowestHP"
local LockedTarget = nil
local PredictionFactor = 0.25
local BodyOffset = Vector3.new(0,2,0)
local CameraDistance = 12
local CameraHeight = 5

-- TARGET FUNCTIONS
local function isValidCharacter(char)
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    return hum and hrp and hum.Health > 0
end

local function isEnemy(player)
    if player == LocalPlayer then return false end
    if not player.Character then return false end
    return true
end

local function getTarget()
    local best,bestValue = nil,math.huge
    local center = Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y/2)
    for _,player in ipairs(Players:GetPlayers()) do
        if isEnemy(player) then
            local char = player.Character
            if isValidCharacter(char) then
                local hrp = char.HumanoidRootPart
                local pos,_ = Camera:WorldToViewportPoint(hrp.Position)
                if TargetPriority == "Center" then
                    local dist = (Vector2.new(pos.X,pos.Y)-center).Magnitude
                    if dist < bestValue then
                        bestValue = dist
                        best = hrp
                    end
                else
                    local hp = char:FindFirstChildOfClass("Humanoid").Health
                    if hp < bestValue then
                        bestValue = hp
                        best = hrp
                    end
                end
            end
        end
    end
    return best
end

-- HARD LOCK LOOP (Camera + Character)
RunService.RenderStepped:Connect(function()
    if not LockEnabled then return end
    local char = LocalPlayer.Character
    local charHRP = char and char:FindFirstChild("HumanoidRootPart")
    if not charHRP then return end

    if not LockedTarget or not LockedTarget.Parent then
        LockedTarget = getTarget()
    end
    if not LockedTarget then return end

    local targetHRP = LockedTarget
    local vel = targetHRP.AssemblyLinearVelocity or targetHRP.Velocity
    local predicted = targetHRP.Position + vel * PredictionFactor + BodyOffset

    -- CHARACTER HARD LOCK
    local flatTarget = Vector3.new(predicted.X,charHRP.Position.Y,predicted.Z)
    charHRP.CFrame = CFrame.lookAt(charHRP.Position,flatTarget)

    -- CAMERA HARD LOCK (behind player)
    local behindPos = charHRP.Position - charHRP.CFrame.LookVector*CameraDistance + Vector3.new(0,CameraHeight,0)
    Camera.CFrame = CFrame.new(behindPos, predicted)
end)

-- GUI SETUP
local gui = Instance.new("ScreenGui")
gui.Name = "TargetsakenUI"
gui.ResetOnSpawn = false
gui.Parent = PlayerGui

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0,250,0,240)
frame.Position = UDim2.new(0.7,0,0.6,0)
frame.BackgroundColor3 = Color3.fromRGB(30,30,30)
frame.Parent = gui
Instance.new("UICorner",frame)

-- HEADER
local header = Instance.new("TextLabel")
header.Size = UDim2.new(1,0,0,30)
header.Position = UDim2.new(0,0,0,0)
header.Text = "TARGETSAKEN"
header.TextScaled = true
header.Font = Enum.Font.SourceSansBold
header.TextColor3 = Color3.fromRGB(255,0,0)
header.BackgroundTransparency = 0.2
header.Parent = frame
Instance.new("UICorner",header)

-- BUTTON CREATOR
local function makeBtn(text,y)
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(1,-10,0,28)
    b.Position = UDim2.new(0,5,0,y)
    b.Text = text
    b.BackgroundColor3 = Color3.fromRGB(50,50,50)
    b.TextColor3 = Color3.new(1,1,1)
    b.Parent = frame
    Instance.new("UICorner",b)
    return b
end

local lockBtn = makeBtn("LOCK: OFF",40)
local prioBtn = makeBtn("PRIORITY: CENTER",70)

-- OPEN/CLOSE BUTTON (DRAGGABLE)
local toggleBtn = Instance.new("TextButton")
toggleBtn.Size = UDim2.new(0,30,0,30)
toggleBtn.Position = UDim2.new(0.7,0,0.55,0)
toggleBtn.Text = "-"
toggleBtn.Parent = gui
toggleBtn.BackgroundColor3 = Color3.fromRGB(50,50,50)
Instance.new("UICorner", toggleBtn)

local guiVisible = true
toggleBtn.MouseButton1Click:Connect(function()
    guiVisible = not guiVisible
    frame.Visible = guiVisible
    toggleBtn.Text = guiVisible and "-" or "+"
end)

-- PREDICTION SLIDER
local predLabel = Instance.new("TextLabel")
predLabel.Size = UDim2.new(1,-10,0,20)
predLabel.Position = UDim2.new(0,5,0,120)
predLabel.Text = "Prediction: "..PredictionFactor
predLabel.TextScaled = true
predLabel.Font = Enum.Font.SourceSans
predLabel.TextColor3 = Color3.new(1,1,1)
predLabel.BackgroundTransparency = 1
predLabel.Parent = frame

local predSlider = Instance.new("TextButton")
predSlider.Size = UDim2.new(1,-10,0,20)
predSlider.Position = UDim2.new(0,5,0,145)
predSlider.BackgroundColor3 = Color3.fromRGB(70,70,70)
predSlider.Text = ""
predSlider.Parent = frame
Instance.new("UICorner", predSlider)

-- DRAGGING PREDICTION SLIDER
local draggingSlider = false
predSlider.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        draggingSlider = true
    end
end)
predSlider.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        draggingSlider = false
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if draggingSlider and input.UserInputType == Enum.UserInputType.MouseMovement then
        local mouseX = math.clamp(input.Position.X - predSlider.AbsolutePosition.X, 0, predSlider.AbsoluteSize.X)
        PredictionFactor = 1 + (mouseX / predSlider.AbsoluteSize.X) * 9
        predLabel.Text = string.format("Prediction: %.2f", PredictionFactor)
    end
end)

-- DRAGGABLE GUI FRAME
local dragging, dragStart, startPos = false, nil, nil
frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = frame.Position
    end
end)
frame.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        frame.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end
end)

-- BUTTON LOGIC
lockBtn.MouseButton1Click:Connect(function()
    LockEnabled = not LockEnabled
    lockBtn.Text = LockEnabled and "LOCK: ON" or "LOCK: OFF"
    if not LockEnabled then LockedTarget = nil end
end)

prioBtn.MouseButton1Click:Connect(function()
    if TargetPriority == "Center" then
        TargetPriority = "LowestHP"
        prioBtn.Text = "PRIORITY: LOW HP"
    else
        TargetPriority = "Center"
        prioBtn.Text = "PRIORITY: CENTER"
    end
    LockedTarget = nil
end)
