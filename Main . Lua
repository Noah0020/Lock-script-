    if TargetType=="Survivor" then
        TargetType="Killer"
        typeButton.Text="KILL"
    else
        TargetType="Survivor"
        typeButton.Text="SURV"
    end
    LockedTarget=nil
end)

priorityButton.MouseButton1Click:Connect(function()
    if TargetPriority=="Center" then
        TargetPriority="LowestHP"
        priorityButton.Text="HP"
    else
        TargetPriority="Center"
        priorityButton.Text="CTR"
    end
    LockedTarget=nil
end)

modeButton.MouseButton1Click:Connect(function()
    if LockMode=="Camera" then
        LockMode="Character"
        modeButton.Text="MODE: Char"
    else
        LockMode="Camera"
        modeButton.Text="MODE: Cam"
    end
end)
