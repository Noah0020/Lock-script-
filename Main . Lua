--!nocheck
--!nolint

if string.split(identifyexecutor() or "None", " ")[1] == "Xeno" then
    getgenv().WebSocket = nil
end

local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/deividcomsono/Obsidian/main/Library.lua"))()

local Window = Library:CreateWindow({
    Title = "Targetsaken by Grok ❤️",
    Footer = "Survivor Ability Hub",
    ToggleKeybind = Enum.KeyCode.RightControl,
    MobileButtonsSide = "Left",
    AutoShow = true,
    Center = true,
    Size = UDim2.fromOffset(420, 380)
})

local Features = {
    AutoAimAbility = false,
    CameraLock = false,
    ESP = false,
    InfStamina = false,
    AutoOtherAbilities = false,
    AutoChange = false
}
local RangeValue = 25
local PredictionValue = 0.25
local LockTargetType = "Survivor"

local PlayersFolder = Workspace:FindFirstChild("Players")
local function GetSurvivors() return PlayersFolder and PlayersFolder:FindFirstChild("Survivors") end
local function GetKillers() return PlayersFolder and PlayersFolder:FindFirstChild("Killers") end

local RayParams = RaycastParams.new()
RayParams.FilterType = Enum.RaycastFilterType.Exclude

local AbilitiesTab = Window:AddTab("Abilities")
local AbGroup = AbilitiesTab:AddGroupbox({Name = "Core Features"})

AbGroup:AddToggle({
    Name = "Auto Aim on Ability Use",
    Default = false,
    Callback = function(state) Features.AutoAimAbility = state end
})

AbGroup:AddToggle({
    Name = "Camera Lock",
    Default = false,
    Callback = function(state) Features.CameraLock = state end
})

AbGroup:AddDropdown({
    Name = "Lock Target",
    Values = {"Survivor", "Killer"},
    Default = "Survivor",
    Callback = function(choice) LockTargetType = choice end
})

AbGroup:AddSlider({
    Name = "Range",
    Min = 0,
    Max = 50,
    Default = 25,
    Callback = function(v) RangeValue = v end
})

AbGroup:AddSlider({
    Name = "Prediction",
    Min = 0,
    Max = 1,
    Default = 0.25,
    Callback = function(v) PredictionValue = v end
})

AbGroup:AddToggle({
    Name = "Auto Other Abilities",
    Default = false,
    Callback = function(state) Features.AutoOtherAbilities = state end
})

AbGroup:AddToggle({
    Name = "Auto Change",
    Default = false,
    Callback = function(state) Features.AutoChange = state end
})

local VisualsTab = Window:AddTab("Visuals")
local VisGroup = VisualsTab:AddGroupbox({Name = "ESP"})

VisGroup:AddToggle({
    Name = "ESP",
    Default = false,
    Callback = function(state) Features.ESP = state end
})

local MiscTab = Window:AddTab("Misc")
local MiscGroup = MiscTab:AddGroupbox({Name = "Misc"})

MiscGroup:AddToggle({
    Name = "Infinite Stamina",
    Default = false,
    Callback = function(state) Features.InfStamina = state end
})

game:GetService("UserInputService").InputBegan:Connect(function(input, gp)
    if gp or not Features.AutoAimAbility or input.UserInputType \~= Enum.UserInputType.MouseButton1 then return end
    
    local myChar = game.Players.LocalPlayer.Character
    if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return end
    local myHRP = myChar.HumanoidRootPart
    
    RayParams.FilterDescendantsInstances = {myChar}
    
    local targetHRP = nil
    local closest = math.huge
    
    local survFolder = GetSurvivors()
    if survFolder then
        for _, char in ipairs(survFolder:GetChildren()) do
            if char \~= myChar and char:FindFirstChild("HumanoidRootPart") then
                local hrp = char.HumanoidRootPart
                local dist = (hrp.Position - myHRP.Position).Magnitude
                if dist <= RangeValue and dist < closest then
                    local ray = Workspace:Raycast(myHRP.Position, (hrp.Position - myHRP.Position), RayParams)
                    if not ray or ray.Distance >= dist - 2 then
                        closest = dist
                        targetHRP = hrp
                    end
                end
            end
        end
    end
    
    if not targetHRP then
        local killFolder = GetKillers()
        if killFolder then
            for _, char in ipairs(killFolder:GetChildren()) do
                if char \~= myChar and char:FindFirstChild("HumanoidRootPart") then
                    local hrp = char.HumanoidRootPart
                    local dist = (hrp.Position - myHRP.Position).Magnitude
                    if dist <= RangeValue and dist < closest then
                        local ray = Workspace:Raycast(myHRP.Position, (hrp.Position - myHRP.Position), RayParams)
                        if not ray or ray.Distance >= dist - 2 then
                            closest = dist
                            targetHRP = hrp
                        end
                    end
                end
            end
        end
    end
    
    if targetHRP then
        local predicted = targetHRP.Position + (targetHRP.Velocity * PredictionValue)
        Workspace.CurrentCamera.CFrame = CFrame.lookAt(Workspace.CurrentCamera.CFrame.Position, predicted)
    end
end)

game:GetService("RunService").RenderStepped:Connect(function()
    local myChar = game.Players.LocalPlayer.Character
    if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return end
    local myHRP = myChar.HumanoidRootPart
    local myHum = myChar:FindFirstChildOfClass("Humanoid")
    
    if Features.InfStamina and myHum then
        myHum:SetAttribute("Stamina", 100)
        local stam = myChar:FindFirstChild("Stamina") or myChar:FindFirstChild("SprintStamina")
        if stam and stam:IsA("NumberValue") then stam.Value = 100 end
    end
    
    if Features.ESP then
        local survFolder = GetSurvivors()
        if survFolder then
            for _, char in ipairs(survFolder:GetChildren()) do
                if not char:FindFirstChild("Highlight") then
                    local hl = Instance.new("Highlight")
                    hl.Adornee = char
                    hl.FillColor = Color3.fromRGB(0, 255, 0)
                    hl.OutlineColor = Color3.fromRGB(255, 255, 255)
                    hl.FillTransparency = 0.6
                    hl.Parent = char
                end
            end
        end
        local killFolder = GetKillers()
        if killFolder then
            for _, char in ipairs(killFolder:GetChildren()) do
                if not char:FindFirstChild("Highlight") then
                    local hl = Instance.new("Highlight")
                    hl.Adornee = char
                    hl.FillColor = Color3.fromRGB(255, 0, 0)
                    hl.OutlineColor = Color3.fromRGB(255, 255, 255)
                    hl.FillTransparency = 0.6
                    hl.Parent = char
                end
            end
        end
    end
    
    if Features.CameraLock then
        local targetHRP = nil
        local closest = math.huge
        RayParams.FilterDescendantsInstances = {myChar}
        
        local folder = (LockTargetType == "Survivor") and GetSurvivors() or GetKillers()
        if folder then
            for _, char in ipairs(folder:GetChildren()) do
                if char \~= myChar and char:FindFirstChild("HumanoidRootPart") then
                    local hrp = char.HumanoidRootPart
                    local dist = (hrp.Position - myHRP.Position).Magnitude
                    if dist <= RangeValue and dist < closest then
                        local ray = Workspace:Raycast(myHRP.Position, (hrp.Position - myHRP.Position), RayParams)
                        if not ray or ray.Distance >= dist - 2 then
                            closest = dist
                            targetHRP = hrp
                        end
                    end
                end
            end
        end
        
        if targetHRP then
            local predicted = targetHRP.Position + (targetHRP.Velocity * PredictionValue)
            Workspace.CurrentCamera.CFrame = CFrame.lookAt(Workspace.CurrentCamera.CFrame.Position, predicted)
        end
    end
    
    if Features.AutoOtherAbilities then
        for _, tool in ipairs(myChar:GetChildren()) do
            if tool:IsA("Tool") and (tool.Name:lower():find("rage") or tool.Name:lower():find("eye") or tool.Name:lower():find("pizza") or tool.Name:lower():find("404")) then
                tool:Activate()
            end
        end
    end
    if Features.AutoChange then
        for _, tool in ipairs(myChar:GetChildren()) do
            if tool:IsA("Tool") then
                tool.Parent = game.Players.LocalPlayer.Backpack
                task.wait(0.5)
                tool.Parent = myChar
                break
            end
        end
    end
end)
